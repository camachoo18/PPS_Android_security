    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.0",
    "jsonwebtoken": "^9.1.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.3.1",
    "swagger-ui-express": "^5.0.0",
    "swagger-ui-themes": "^4.0.0",
    "prisma": "^5.7.0",
    "@prisma/client": "^5.7.0",
    "nodemailer": "^6.9.7",
    "redis": "^4.6.12",
    "morgan": "^1.10.0",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.54.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0"
