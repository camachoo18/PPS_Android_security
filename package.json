  "description": "API REST segura para aplicación de registro de IMC",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "lint": "eslint .",
    "security-audit": "npm audit",
